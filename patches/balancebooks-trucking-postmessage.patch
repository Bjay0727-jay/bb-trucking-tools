From 092294cbd01c2800ab65f85a97a94d8d753f983e Mon Sep 17 00:00:00 2001
From: Claude <noreply@anthropic.com>
Date: Fri, 13 Feb 2026 17:30:42 +0000
Subject: [PATCH] Add postMessage integration for cross-origin tools import
MIME-Version: 1.0
Content-Type: text/plain; charset=UTF-8
Content-Transfer-Encoding: 8bit

Replace localStorage-based import detection with postMessage listener
for secure cross-subdomain data transfer from tools.balancebooksapp.com.

Changes:
- Listen for 'bb-tools-import' postMessage events with origin validation
- Send acknowledgment back to stop sender retries
- Support #bbdata= URL hash fallback (when popup blocked)
- Keep legacy base64 hash + localStorage fallback for dev
- Add cost-per-mile import → updates app settings
- Add deadhead-calculator import → creates load entry with cost analysis
- Fix per-diem import to handle v2 payload format (perDiem.fullDays)
- Update ToolsImportModal with summaries for all 6 tool sources

https://claude.ai/code/session_01VVVSrHYTofQSDgBXR3GUHu
---
 src/App.jsx                     | 186 ++++++++++++++++++++++++--------
 src/modals/ToolsImportModal.jsx |  39 ++++++-
 2 files changed, 175 insertions(+), 50 deletions(-)

diff --git a/src/App.jsx b/src/App.jsx
index c45aac0..36e633d 100644
--- a/src/App.jsx
+++ b/src/App.jsx
@@ -378,13 +378,62 @@ export default function App() {
   };
   // ============================================
   // TOOLS IMPORT DETECTION (bb-trucking-tools integration)
-  // Uses URL hash for cross-domain data transfer
+  // Uses postMessage (cross-origin) + URL hash fallback
   // ============================================
-  
+
   useEffect(() => {
     if (isLoading) return; // Wait for app to load first
-    
-    const checkForToolsImport = () => {
+
+    const TOOLS_ORIGIN = 'https://tools.balancebooksapp.com';
+
+    // Handler for incoming tool data (shared by both methods)
+    const processImportData = (data) => {
+      // Validate source
+      const validSources = ['fuel-converter', 'ifta-calculator', 'load-calculator', 'cost-per-mile', 'per-diem', 'deadhead-calculator'];
+      if (!validSources.includes(data.source)) {
+        setToolsImportError('Invalid import source: ' + data.source);
+        return;
+      }
+
+      // Check timestamp (reject if older than 1 hour)
+      if (data.timestamp) {
+        const importTime = new Date(data.timestamp);
+        if (new Date() - importTime > 60 * 60 * 1000) {
+          setToolsImportError('Import data expired. Please export again from tools.');
+          return;
+        }
+      }
+
+      // Valid import - show confirmation modal
+      console.log('[Tools Import] Valid data from:', data.source, '- Showing modal');
+      setToolsImportData(data);
+      setShowToolsImport(true);
+      setToolsImportError(null);
+    };
+
+    // Method 1: Listen for postMessage from tools site (cross-origin)
+    const handleMessage = (event) => {
+      // In development, also accept localhost origins
+      const isDev = window.location.hostname === 'localhost' || window.location.hostname === '127.0.0.1';
+      const isValidOrigin = event.origin === TOOLS_ORIGIN || (isDev && event.origin.includes('localhost'));
+
+      if (!isValidOrigin) return;
+      if (!event.data || event.data.type !== 'bb-tools-import') return;
+
+      console.log('[Tools Import] Data received via postMessage');
+
+      // Acknowledge receipt so sender stops retrying
+      if (event.source) {
+        event.source.postMessage({ type: 'bb-tools-ack' }, event.origin);
+      }
+
+      processImportData(event.data.payload);
+    };
+
+    window.addEventListener('message', handleMessage);
+
+    // Method 2: Check URL hash for encoded data (same-tab fallback when popup blocked)
+    const checkUrlImport = () => {
       const urlParams = new URLSearchParams(window.location.search);
       if (urlParams.get('import') !== 'tools') return;
 
@@ -392,65 +441,50 @@ export default function App() {
 
       try {
