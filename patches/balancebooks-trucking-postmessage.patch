             };
-            
+
             setPerDiemDays(prev => [...prev, newPerDiem]);
             setActiveTab('perdiem');
+            console.log('[Tools Import] Added per diem entry: ' + pdDays + ' full days, ' + pdPartialDays + ' partial days');
+          }
+          break;
+
+        case 'cost-per-mile':
+          if (toolsImportData.settings) {
+            const cpmSettings = toolsImportData.settings;
+            // Merge CPM data into app settings
+            setSettings(prev => ({
+              ...prev,
+              monthlyMiles: cpmSettings.monthlyMiles || prev.monthlyMiles,
+              costPerMile: cpmSettings.calculated?.totalCPM || prev.costPerMile,
+              fixedCosts: cpmSettings.fixedCosts || prev.fixedCosts,
+              variableCosts: cpmSettings.variableCosts || prev.variableCosts,
+              breakEvenRate: cpmSettings.calculated?.breakEvenRate || cpmSettings.calculated?.totalCPM || 0,
+              recommendedRate: cpmSettings.calculated?.recommendedRate20 || (cpmSettings.calculated?.totalCPM / 0.80) || 0
