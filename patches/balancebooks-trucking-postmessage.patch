+            setActiveTab('settings');
+            console.log('[Tools Import] Updated cost-per-mile settings: $' + (cpmSettings.calculated?.totalCPM || 0).toFixed(2) + '/mi');
+          }
+          break;
+
+        case 'deadhead-calculator':
